# Azure DevOps Configuration (required)
AZURE_DEVOPS_PAT=your-pat-here
AZURE_DEVOPS_ORG=your-org-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_REPO_IDS=repo-guid-1,repo-guid-2
TARGET_REPO_PATH=C:/path/to/local/clone

# Optional: Polling interval in minutes (default: 30)
# POLL_INTERVAL_MINUTES=30

# Optional: Maximum reviews per day (default: 10)
# MAX_REVIEWS_PER_DAY=10

# Optional: Label that triggers review (default: code-review)
# REVIEW_LABEL=code-review

# Optional: Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: State file directory (default: .state)
# STATE_DIR=.state
